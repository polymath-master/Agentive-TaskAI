# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# GOOGLE_CLIENT_ID: Your Google OAuth 2.0 Client ID (Web or Android).
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

# GOOGLE_CLIENT_SECRET: Your Google OAuth 2.0 Client Secret (only required if using Web Client).
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# GOOGLE_REDIRECT_URI: The OAuth 2.0 redirect URI scheme.
# For Android / Desktop client type: com.aistudio.agentivetaskai://oauth2redirect
# For Web application client type (with registered domain): https://agentivetaskai.com/oauth2redirect
# For Web application client type (without registered domain - official Google loopback): http://localhost/oauth2redirect
GOOGLE_REDIRECT_URI=http://localhost/oauth2redirect

